{
  "name": "finch",
  "version": "0.4.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "finch": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build --compile ./src/index.ts --outfile finch",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 ./src/index.ts --outfile dist/finch-darwin-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 ./src/index.ts --outfile dist/finch-darwin-x64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile dist/finch-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 ./src/index.ts --outfile dist/finch-linux-arm64",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "preflight": "git rev-parse HEAD && bun run build && ./finch --version",
    "rehearse": "./scripts/e2e-rehearsal.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xdevplatform/xdk": "^0.5.0",
    "zod": "^4.4.3"
  }
}
